<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<VersionPrefix>1.0.0</VersionPrefix>
		<Description>Domain exception hierarchy (Domain / Error / Exist / NotFound / Validation) with traceable metadata: id, type, error code, HTTP code and timestamp</Description>
		<PackageTags>exception,domain,ddd,error,validation,http</PackageTags>
	</PropertyGroup>

	<ItemGroup>
		<None Include="README.md" Pack="True" PackagePath="\" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="JorgeCostaMacia.GuidFactory" Version="1.0.0" />
		<PackageReference Include="FluentValidation" Version="11.12.0" Condition="'$(TargetFramework)' == 'net6.0' or '$(TargetFramework)' == 'net7.0'" />
		<PackageReference Include="FluentValidation" Version="12.1.1" Condition="'$(TargetFramework)' != 'net6.0' and '$(TargetFramework)' != 'net7.0'" />
	</ItemGroup>

</Project>
